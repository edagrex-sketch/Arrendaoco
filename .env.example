APP_NAME=ArrendaOco
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
#  BASE DE DATOS  (MySQL local)
# ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bd_arrendaoco
DB_USERNAME=root
DB_PASSWORD=

# ─────────────────────────────────────────────
#  SESIÓN / CACHÉ
# ─────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────
#  CORREO (usa los datos del líder o configura el tuyo)
# ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@arrendaoco.test"
MAIL_FROM_NAME="ArrendaOco"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
#  API KEYS (pide los valores al líder del proyecto)
# ─────────────────────────────────────────────
GEMINI_API_KEY=
YOUTUBE_API_KEY=

# ─────────────────────────────────────────────
#  LOGIN CON GOOGLE (pide las credenciales al líder u ocupen éstas ya configuradas)
#  URI de callback: http://127.0.0.1:8000/auth/google/callback
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=124011093090-h20mtr6apuabm18a1frp71kofcuqq715.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI="http://127.0.0.1:8000/auth/google/callback"

# ─────────────────────────────────────────────
#  LOGIN CON FACEBOOK (pide las credenciales al líder)
#  URI de callback: http://127.0.0.1:8000/auth/facebook/callback
# ─────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="http://127.0.0.1:8000/auth/facebook/callback"